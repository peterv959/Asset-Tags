{
  "name": "asset-tags",
  "version": "0.0.1",
  "description": "Asset Tag Generation",
  "private": true,
  "workspaces": [
    "packages/Asset-Tags",
    "packages/shared",
    "packages/ui"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start": "npm --workspace=packages/Asset-Tags run start",
    "dev": "npm --workspace=packages/Asset-Tags run dev",
    "watch": "npm run watch --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rimraf node_modules packages/*/node_modules"
  },
  "keywords": [],
  "author": "Peter R. Vermilye",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0",
    "rimraf": "^5.0.0"
  },
  "dependencies": {
    "jsbarcode": "^3.11.5",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "build": {
    "appId": "com.dhl.assettags",
    "productName": "DHL Asset Tags",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "icon": "assets/barcode.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
